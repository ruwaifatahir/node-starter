generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model BotGroup {
  id           String     @id
  groupId      String     @unique
  groupTitle   String?
  addedBy      String
  addedAt      DateTime   @default(now())
  isActive     Boolean    @default(true)
  minBuy       Float      @default(30)
  emoji        String     @default("🟢")
  mediaType    MediaType?
  mediaUrl     String?
  website      String?
  telegram     String?
  x            String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  tokenAddress String?
}

model BoostOrder {
  id                     String        @id
  telegramChatId         BigInt
  tokenAddress           String
  boostPackage           String
  boostDurationHours     Int
  price                  Float
  paymentAddress         String        @unique
  paymentPrivateKey      String
  paymentStatus          PaymentStatus @default(PENDING)
  boostStartedAt         DateTime?
  boostEndsAt            DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime
  paymentTransactionHash String?
  refundAddress          String?
  refundTransactionHash  String?
  emoji                  String?       @default("🐳")
  userId                 String
  website                String?
  telegram               String?
  x                      String?
}

model ProcessedAlert {
  id           String   @id @default(uuid())
  txHash       String
  tokenAddress String
  destination  String
  createdAt    DateTime @default(now())

  @@unique([txHash, tokenAddress, destination])
}

enum MediaType {
  PHOTO
  VIDEO
  ANIMATION
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  EXPIRED
  PROCESSING
}
